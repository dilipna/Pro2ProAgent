# Copy this file to .env and fill in the values you have.
# Nothing in P2POps requires all of these at once -- each milestone only
# needs the keys relevant to it.

ENVIRONMENT=development

# --- LLM access, routed through LiteLLM ---
# "anthropic" (direct), "openrouter", or "groq" -- switching is a config change, no code change.
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=

# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# https://console.groq.com/keys -- fast inference, good fallback when other
# providers are out of credit
GROQ_API_KEY=

# --- Observability ---
# https://smith.langchain.com/ -> Settings -> API Keys
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=p2pops
# https://logfire.pydantic.dev/ -> project -> write token
LOGFIRE_TOKEN=

# --- Discovery sources (Milestone 2+) ---
# https://www.reddit.com/prefs/apps -> create app -> "script" type
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- HITL orchestration (human gate, ADR-0002) ---
REVIEW_INTERVAL_DAYS=10
# Where review-request emails go. Empty = printed to the server log instead.
REVIEW_EMAIL_TO=
# https://resend.com -> API keys. Empty = console adapter (no real email).
RESEND_API_KEY=
# Base URL used inside approve/reject links (the p2pops-api host).
APP_BASE_URL=http://localhost:8000

# --- API ---
# Optional bearer token required for mutating endpoints (POST /api/v1/runs).
API_TOKEN=

# --- Product publishing (build-squad publish stage) ---
# https://vercel.com/account/tokens. Empty = publish stage skips honestly
# (builds complete but no live URL is claimed).
VERCEL_TOKEN=
# Optional; defaults to the token's default team.
VERCEL_TEAM_ID=

# --- Public keyword search (spend controls) ---
SEARCH_REQUESTS_PER_HOUR_PER_CLIENT=3
SEARCH_RUNS_PER_DAY=8
SEARCH_DEDUPE_HOURS=24
# Daily estimated LLM spend (USD) above which public search stops starting
# runs and the console shows a cost alert. Operator runs are not blocked.
DAILY_COST_CEILING_USD=1.0
